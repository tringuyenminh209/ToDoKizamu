                <mxCell id="e31" value="Trigger" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeWidth=2;strokeColor=#b85450;fontColor=#b85450;fontSize=10;html=1" parent="1" source="71" target="72" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="e32" value="Push Image" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeWidth=2;strokeColor=#b85450;fontColor=#b85450;fontSize=10;html=1" parent="1" source="72" target="73" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="e33" value="Pull" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeWidth=2;strokeColor=#b85450;fontColor=#b85450;fontSize=10;html=1" parent="1" source="73" target="74" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="e34" value="Deploy" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeWidth=2;strokeColor=#b85450;fontColor=#b85450;fontSize=10;html=1" parent="1" source="74" target="75" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
            </root>
        </mxGraphModel>
    </diagram>
    <diagram id="page2-notes" name="Component Notes">
        <mxGraphModel dx="1499" dy="922" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2339" pageHeight="1654" math="0" shadow="0">
            <root>
                <mxCell id="0"/>
                <mxCell id="1" parent="0"/>
                <mxCell id="t0" value="TodoApp — AWS Architecture Component Notes" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=22;fontStyle=1" parent="1" vertex="1">
                    <mxGeometry x="400" y="30" width="1500" height="40" as="geometry"/>
                </mxCell>
                <mxCell id="t0b" value="Stack: Laravel 11 (PHP 8.3) · Next.js 15 · MySQL 8.0 · Redis 7 · Android Kotlin · Laravel Reverb (WebSocket) · OpenAI · Firebase FCM" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=13;fontStyle=2" parent="1" vertex="1">
                    <mxGeometry x="200" y="75" width="1900" height="30" as="geometry"/>
                </mxCell>
                <mxCell id="n1h" value="Edge Layer" style="rounded=1;arcSize=3;strokeColor=#F48FB1;fillColor=#FCE8F3;align=left;verticalAlign=middle;spacingLeft=10;fontSize=14;fontStyle=1;html=1" parent="1" vertex="1">
                    <mxGeometry x="40" y="130" width="560" height="40" as="geometry"/>
                </mxCell>
                <mxCell id="n1" value="&lt;b&gt;Route 53&lt;/b&gt; — DNS routing. Maps domain to CloudFront distribution.&#10;&lt;b&gt;CloudFront&lt;/b&gt; — CDN. Caches Next.js static assets globally; accelerates API responses.&#10;&lt;b&gt;AWS WAF&lt;/b&gt; — Web Application Firewall. Blocks SQL injection, XSS, rate-limits bot traffic.&#10;&lt;b&gt;ACM&lt;/b&gt; — AWS Certificate Manager. Provisions and auto-renews SSL/TLS certificates." style="text;html=1;strokeColor=#F48FB1;fillColor=#FCE8F3;align=left;verticalAlign=top;spacingTop=8;spacingLeft=10;rounded=1;arcSize=2;fontSize=12;whiteSpace=wrap" parent="1" vertex="1">
                    <mxGeometry x="40" y="175" width="560" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="n2h" value="Networking (VPC)" style="rounded=1;arcSize=3;strokeColor=#8C4FFF;fillColor=#F5F0FF;align=left;verticalAlign=middle;spacingLeft=10;fontSize=14;fontStyle=1;html=1" parent="1" vertex="1">
                    <mxGeometry x="40" y="320" width="560" height="40" as="geometry"/>
                </mxCell>
                <mxCell id="n2" value="&lt;b&gt;VPC 10.0.0.0/16&lt;/b&gt; — Isolated network in ap-northeast-1 (Tokyo).&#10;&lt;b&gt;Internet Gateway&lt;/b&gt; — Entry point for inbound internet traffic.&#10;&lt;b&gt;ALB (Application Load Balancer)&lt;/b&gt; — Routes HTTP/WebSocket traffic to ECS tasks by port (:3000 Next.js, :8080 API, :8081 Reverb).&#10;&lt;b&gt;NAT Gateway&lt;/b&gt; — Allows private subnet containers to reach internet (OpenAI, FCM) without exposing them." style="text;html=1;strokeColor=#8C4FFF;fillColor=#F5F0FF;align=left;verticalAlign=top;spacingTop=8;spacingLeft=10;rounded=1;arcSize=2;fontSize=12;whiteSpace=wrap" parent="1" vertex="1">
                    <mxGeometry x="40" y="365" width="560" height="130" as="geometry"/>
                </mxCell>
                <mxCell id="n3h" value="Compute (ECS Fargate)" style="rounded=1;arcSize=3;strokeColor=#E7157B;fillColor=#FCE8F3;align=left;verticalAlign=middle;spacingLeft=10;fontSize=14;fontStyle=1;html=1" parent="1" vertex="1">
                    <mxGeometry x="40" y="520" width="560" height="40" as="geometry"/>
                </mxCell>
                <mxCell id="n3" value="&lt;b&gt;Next.js 15 Task&lt;/b&gt; — Serverside-rendered frontend. Handles SSR, API routes, Zustand state, React Query.&#10;&lt;b&gt;Laravel 11 API Task&lt;/b&gt; — REST API backend. Auth (Sanctum), CRUD todos, AI integration, queue dispatch.&#10;&lt;b&gt;Laravel Reverb Task&lt;/b&gt; — WebSocket server (port 8081). Real-time todo updates via Echo + Pusher.js. Uses Redis pub/sub internally." style="text;html=1;strokeColor=#E7157B;fillColor=#FCE8F3;align=left;verticalAlign=top;spacingTop=8;spacingLeft=10;rounded=1;arcSize=2;fontSize=12;whiteSpace=wrap" parent="1" vertex="1">
                    <mxGeometry x="40" y="565" width="560" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="n4h" value="Database" style="rounded=1;arcSize=3;strokeColor=#2E73B8;fillColor=#EEF4FB;align=left;verticalAlign=middle;spacingLeft=10;fontSize=14;fontStyle=1;html=1" parent="1" vertex="1">
                    <mxGeometry x="40" y="710" width="560" height="40" as="geometry"/>
                </mxCell>
                <mxCell id="n4" value="&lt;b&gt;RDS MySQL 8.0&lt;/b&gt; — Primary relational DB. Stores users, todos, tags, notifications, AI knowledge. Multi-AZ for HA.&#10;&lt;b&gt;ElastiCache Redis 7&lt;/b&gt; — Dual role: (1) Cache layer for sessions &amp; queries. (2) Queue backend for Laravel Horizon/SQS workers. (3) Pub/Sub channel for Reverb real-time broadcast." style="text;html=1;strokeColor=#2E73B8;fillColor=#EEF4FB;align=left;verticalAlign=top;spacingTop=8;spacingLeft=10;rounded=1;arcSize=2;fontSize=12;whiteSpace=wrap" parent="1" vertex="1">
                    <mxGeometry x="40" y="755" width="560" height="110" as="geometry"/>
                </mxCell>
                <mxCell id="n5h" value="Storage &amp; Messaging" style="rounded=1;arcSize=3;strokeColor=#F0A500;fillColor=#FFF8EE;align=left;verticalAlign=middle;spacingLeft=10;fontSize=14;fontStyle=1;html=1" parent="1" vertex="1">
                    <mxGeometry x="640" y="130" width="560" height="40" as="geometry"/>
                </mxCell>
                <mxCell id="n5" value="&lt;b&gt;S3&lt;/b&gt; — Object storage for user file uploads and static assets served via CloudFront.&#10;&lt;b&gt;SQS&lt;/b&gt; — Message queue for async jobs: email sending, AI processing, push notification dispatch.&#10;&lt;b&gt;SNS&lt;/b&gt; — Fan-out notifications to multiple subscribers (email, SMS, Lambda triggers)." style="text;html=1;strokeColor=#F0A500;fillColor=#FFF8EE;align=left;verticalAlign=top;spacingTop=8;spacingLeft=10;rounded=1;arcSize=2;fontSize=12;whiteSpace=wrap" parent="1" vertex="1">
                    <mxGeometry x="640" y="175" width="560" height="110" as="geometry"/>
                </mxCell>
                <mxCell id="n6h" value="Security" style="rounded=1;arcSize=3;strokeColor=#DD344C;fillColor=#FDECEA;align=left;verticalAlign=middle;spacingLeft=10;fontSize=14;fontStyle=1;html=1" parent="1" vertex="1">
                    <mxGeometry x="640" y="310" width="560" height="40" as="geometry"/>
                </mxCell>
                <mxCell id="n6" value="&lt;b&gt;Secrets Manager&lt;/b&gt; — Stores DB credentials, API keys (OpenAI, FCM), Reverb keys. Auto-rotated.&#10;&lt;b&gt;IAM&lt;/b&gt; — ECS Task Roles grant least-privilege access to S3, SQS, Secrets Manager, CloudWatch.&#10;&lt;b&gt;Laravel Sanctum&lt;/b&gt; — Token-based auth for API. SPA cookies for Next.js frontend. Mobile tokens for Android." style="text;html=1;strokeColor=#DD344C;fillColor=#FDECEA;align=left;verticalAlign=top;spacingTop=8;spacingLeft=10;rounded=1;arcSize=2;fontSize=12;whiteSpace=wrap" parent="1" vertex="1">
                    <mxGeometry x="640" y="355" width="560" height="110" as="geometry"/>
                </mxCell>
                <mxCell id="n7h" value="Observability" style="rounded=1;arcSize=3;strokeColor=#E7157B;fillColor=#FCE8F3;align=left;verticalAlign=middle;spacingLeft=10;fontSize=14;fontStyle=1;html=1" parent="1" vertex="1">
                    <mxGeometry x="640" y="490" width="560" height="40" as="geometry"/>
                </mxCell>
                <mxCell id="n7" value="&lt;b&gt;CloudWatch Logs&lt;/b&gt; — Collects stdout/stderr from all ECS containers. Centralized log retention.&#10;&lt;b&gt;CloudWatch Metrics&lt;/b&gt; — CPU, memory, request latency dashboards. Alarms trigger SNS on threshold breach.&#10;&lt;b&gt;ECR&lt;/b&gt; — Private Docker image registry. Stores backend, frontend, and Reverb container images." style="text;html=1;strokeColor=#E7157B;fillColor=#FCE8F3;align=left;verticalAlign=top;spacingTop=8;spacingLeft=10;rounded=1;arcSize=2;fontSize=12;whiteSpace=wrap" parent="1" vertex="1">
                    <mxGeometry x="640" y="535" width="560" height="110" as="geometry"/>
                </mxCell>
                <mxCell id="n8h" value="External Integrations" style="rounded=1;arcSize=3;strokeColor=#555555;fillColor=#f5f5f5;align=left;verticalAlign=middle;spacingLeft=10;fontSize=14;fontStyle=1;html=1" parent="1" vertex="1">
                    <mxGeometry x="640" y="670" width="560" height="40" as="geometry"/>
                </mxCell>
                <mxCell id="n8" value="&lt;b&gt;OpenAI API&lt;/b&gt; — AI todo suggestions, smart categorization, knowledge extraction. Called from Laravel via NAT Gateway.&#10;&lt;b&gt;Firebase FCM&lt;/b&gt; — Push notification delivery to Android devices. Laravel dispatches FCM HTTP v1 API calls via SQS worker.&#10;&lt;b&gt;Android App (Kotlin)&lt;/b&gt; — MVVM + Retrofit. Connects to ALB REST API + WebSocket. Room DB for offline caching." style="text;html=1;strokeColor=#555555;fillColor=#f5f5f5;align=left;verticalAlign=top;spacingTop=8;spacingLeft=10;rounded=1;arcSize=2;fontSize=12;whiteSpace=wrap" parent="1" vertex="1">
                    <mxGeometry x="640" y="715" width="560" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="n9h" value="CI/CD Pipeline" style="rounded=1;arcSize=3;strokeColor=#b85450;fillColor=#f8cecc;align=left;verticalAlign=middle;spacingLeft=10;fontSize=14;fontStyle=1;html=1" parent="1" vertex="1">
                    <mxGeometry x="1240" y="130" width="1060" height="40" as="geometry"/>
                </mxCell>
                <mxCell id="n9" value="&lt;b&gt;Flow:&lt;/b&gt;  GitHub (push/PR)  →  GitHub Actions  →  AWS CodeBuild (docker build + test)  →  ECR (push image)  →  CodeDeploy (blue/green)  →  ECS Service Update&#10;&#10;&lt;b&gt;GitHub Actions&lt;/b&gt; — Orchestrates the pipeline. Runs PHP/JS unit tests before build.&#10;&lt;b&gt;CodeBuild&lt;/b&gt; — Builds Docker images for backend (Laravel + Nginx), frontend (Next.js), reverb (WebSocket server).&#10;&lt;b&gt;ECR&lt;/b&gt; — Stores versioned images. Image scanning enabled for vulnerability detection.&#10;&lt;b&gt;CodeDeploy&lt;/b&gt; — Blue/green deployment to ECS. Automatic rollback on health-check failure.&#10;&lt;b&gt;ECS Rolling Update&lt;/b&gt; — Deploys new task definition. Zero-downtime with minimum healthy 100%." style="text;html=1;strokeColor=#b85450;fillColor=#f8cecc;align=left;verticalAlign=top;spacingTop=8;spacingLeft=10;rounded=1;arcSize=2;fontSize=12;whiteSpace=wrap" parent="1" vertex="1">
                    <mxGeometry x="1240" y="175" width="1060" height="200" as="geometry"/>
                </mxCell>
                <mxCell id="n10h" value="Traffic Flow Summary" style="rounded=1;arcSize=3;strokeColor=#6c8ebf;fillColor=#dae8fc;align=left;verticalAlign=middle;spacingLeft=10;fontSize=14;fontStyle=1;html=1" parent="1" vertex="1">
                    <mxGeometry x="1240" y="410" width="1060" height="40" as="geometry"/>
                </mxCell>
                <mxCell id="n10" value="&lt;b&gt;Browser Request:&lt;/b&gt;  User → Route53 → CloudFront → WAF → ALB → Next.js (Fargate) → Laravel API → MySQL/Redis&#10;&lt;b&gt;Android REST:&lt;/b&gt;  App → WAF → ALB :8080 → Laravel API → MySQL/Redis → Response&#10;&lt;b&gt;WebSocket:&lt;/b&gt;  Browser/App → ALB :8081 → Laravel Reverb → Redis Pub/Sub → Broadcast to connected clients&#10;&lt;b&gt;Push Notification:&lt;/b&gt;  Laravel API → SQS → Worker → FCM API → Android Device&#10;&lt;b&gt;AI Feature:&lt;/b&gt;  Laravel API → NAT GW → OpenAI API → AI response → stored in MySQL&#10;&lt;b&gt;File Upload:&lt;/b&gt;  Laravel API → S3 PutObject (pre-signed URL for direct client upload)" style="text;html=1;strokeColor=#6c8ebf;fillColor=#dae8fc;align=left;verticalAlign=top;spacingTop=8;spacingLeft=10;rounded=1;arcSize=2;fontSize=12;whiteSpace=wrap" parent="1" vertex="1">
                    <mxGeometry x="1240" y="455" width="1060" height="190" as="geometry"/>
                </mxCell>
                <mxCell id="n11h" value="Sizing &amp; Cost Notes" style="rounded=1;arcSize=3;strokeColor=#82b366;fillColor=#d5e8d4;align=left;verticalAlign=middle;spacingLeft=10;fontSize=14;fontStyle=1;html=1" parent="1" vertex="1">
                    <mxGeometry x="1240" y="670" width="1060" height="40" as="geometry"/>
                </mxCell>
                <mxCell id="n11" value="&lt;b&gt;ECS Fargate&lt;/b&gt; — Start small: 0.5 vCPU / 1GB per task. Auto-scaling on ALB request count.&#10;&lt;b&gt;RDS&lt;/b&gt; — db.t3.medium for dev; db.r6g.large for production. Enable Multi-AZ for HA.&#10;&lt;b&gt;ElastiCache&lt;/b&gt; — cache.t3.micro for dev; cache.r6g.large + cluster mode for production.&#10;&lt;b&gt;NAT Gateway&lt;/b&gt; — Charged per GB processed. Consider VPC endpoints for S3/SQS to reduce cost.&#10;&lt;b&gt;CloudFront&lt;/b&gt; — Free tier covers 1TB/month. Cache TTL tuning critical for Next.js static assets." style="text;html=1;strokeColor=#82b366;fillColor=#d5e8d4;align=left;verticalAlign=top;spacingTop=8;spacingLeft=10;rounded=1;arcSize=2;fontSize=12;whiteSpace=wrap" parent="1" vertex="1">
                    <mxGeometry x="1240" y="715" width="1060" height="160" as="geometry"/>
                </mxCell>
            </root>
        </mxGraphModel>
    </diagram>
</mxfile>